# Claude Code
CLAUDE.md
# aa-ma-forge IS the AA-MA framework — its own AA-MA task artifacts
# (.claude/dev/active/, .claude/dev/completed/) are intentional deliverables
# and MUST be version-controlled. The rest of .claude/ (session state, memory,
# local caches, per-project auto-memory) remains ignored via explicit child
# exclusions — excluding .claude/ wholesale blocks git from descending into it.
.claude/*
!.claude/dev/
.claude/projects/
.claude/cache/
.claude/memory/
PROJECT_INDEX.json
drafts/
media/

# codemem local state — never commit
.codemem/

# git worktrees — sibling working trees for parallel feature work (L-066)
.worktrees/

# Hypothesis property-test cache (test state, not source)
.hypothesis/

# /retro skill output — per-developer weekly retrospective JSON snapshots
.context/

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/

# Environment
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
.research/
.aider*

# Untracked research / strategy / private working notes
private/

# Coverage build artifacts (added 2026-05-17 during aa-ma-tui-tracker M1
# when pytest-cov landed as a dev dep)
.coverage
.coverage.*
htmlcov/
coverage.xml

# pytest-textual-snapshot failure report (regenerated on failure; never commit)
snapshot_report.html
